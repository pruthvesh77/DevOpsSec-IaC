[mysqld]
# Basic settings
bind-address = 0.0.0.0 # Allow connections from any IP (adjust for security)
mysql_native_password = ON # Required for older client connections (adjust if needed)

# Logging settings
log_error = /var/log/mysql/error.log
general_log_file = /var/log/mysql/general.log
general_log = 1

# Buffer settings
innodb_buffer_pool_size = 256M
key_buffer_size = 64M